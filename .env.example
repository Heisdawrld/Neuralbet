# ═══════════════════════════════════════════════════════════════
# NeuralBet — Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# BSD API (Bzzoiro Sports Data v2)
BSD_API_KEY=your_bsd_api_key_here
BSD_API_BASE_URL=https://sports.bzzoiro.com/api/v2/

# Turso Database
TURSO_DB_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Database URL (local fallback)
DATABASE_URL=file:db/neuralbet.db
